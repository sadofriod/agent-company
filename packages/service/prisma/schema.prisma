generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AgentMarkdown {
  id               String   @id @default(cuid())
  path             String   @unique
  storageProvider  String   @map("storage_provider")
  storagePath      String   @map("storage_path")
  name             String
  category         String
  description      String?
  profile          String?
  toolPolicy       String?  @map("tool_policy")
  partials         String[] @default([])
  tools            String[] @default([])
  allowedCommands  String[] @default([]) @map("allowed_commands")
  requiredCommands String[] @default([]) @map("required_commands")
  frontMatter      Json?    @map("front_matter")
  size             Int
  storageUpdatedAt DateTime @map("storage_updated_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("agent_markdowns")
}

model TeamSchema {
  id        String   @id @default(cuid())
  key       String   @unique
  document  Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_schemas")
}

model RuntimeEvent {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  sequence   Int
  eventId    String   @unique @map("event_id")
  eventType  String   @map("event_type")
  ts         DateTime
  traceId    String   @map("trace_id")
  level      String
  actor      Json?
  target     Json?
  statePatch Json?    @map("state_patch_json")
  metrics    Json?    @map("metrics_json")
  payload    Json     @map("payload_json")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([sessionId, sequence])
  @@index([sessionId, sequence])
  @@map("runtime_events")
}

model RuntimeSnapshot {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  sequence   Int
  traceId    String   @map("trace_id")
  snapshot   Json     @map("snapshot_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([sessionId, sequence])
  @@index([sessionId, updatedAt])
  @@map("runtime_snapshots")
}