{
  "schema_version": "0.1.0",
  "team_id": "discussion-blackboard-team",
  "team_name": "Discussion Blackboard Team",
  "departments": [
    {
      "department_id": "strategy",
      "name": "Strategy",
      "mission": "Frame the business direction, release scope, and executive narrative.",
      "decision_scope": ["strategy", "roadmap", "priority", "executive_alignment"],
      "agents": ["ceo"],
      "handoff_contracts": ["strategy_ticket"]
    },
    {
      "department_id": "engineering",
      "name": "Engineering",
      "mission": "Design technical execution paths and deliver implementation-ready plans.",
      "decision_scope": ["architecture", "implementation", "verification", "engineering_delivery"],
      "agents": ["cto"],
      "handoff_contracts": ["engineering_ticket"]
    },
    {
      "department_id": "content",
      "name": "Content",
      "mission": "Create narrative assets, launch messaging, and audience-facing deliverables.",
      "decision_scope": ["content_strategy", "launch_copy", "campaign_narrative"],
      "agents": ["content_leader"],
      "handoff_contracts": ["content_ticket"]
    }
  ],
  "agents": [
    {
      "agent_id": "ceo",
      "department_id": "strategy",
      "role": "Topic Owner",
      "model": "default-reasoning-model",
      "metadata": {
        "name": "CEO",
        "description": "Reads the shared discussion blackboard, frames the release strategy, and writes executive-level priorities back into the discussion.",
        "profile": "strategy",
        "tool_policy": "planning_only",
        "allowed_commands": ["CHECK_IN", "NEW_TICKET"],
        "required_commands": ["CHECK_IN"]
      },
      "description": "Turns the upstream goal into a strategy ticket with release framing and business constraints.",
      "responsibilities": ["clarify_goal", "set_priority", "frame_strategy_ticket"],
      "input_contract": "discussion_blackboard",
      "output_contract": "strategy_ticket",
      "skills": ["roadmap_planning", "goal_alignment"],
      "mcp_servers": [],
      "tools": [],
      "memory_access_policy": "strategy_owner_policy"
    },
    {
      "agent_id": "cto",
      "department_id": "engineering",
      "role": "Department Owner",
      "model": "default-reasoning-model",
      "metadata": {
        "name": "CTO",
        "description": "Reads the shared discussion blackboard, proposes technical execution paths, and writes engineering risks and delivery plans back into the discussion.",
        "profile": "architecture",
        "tool_policy": "read_heavy",
        "allowed_commands": ["CHECK_IN", "NEW_TICKET", "DELIVERABLE"],
        "required_commands": ["CHECK_IN"]
      },
      "description": "Turns the discussion into an engineering ticket with implementation and verification requirements.",
      "responsibilities": ["technical_planning", "risk_review", "frame_engineering_ticket"],
      "input_contract": "discussion_blackboard",
      "output_contract": "engineering_ticket",
      "skills": ["technical_planning", "release_architecture"],
      "mcp_servers": ["repository"],
      "tools": ["search", "read_file", "edit_file", "run_tests"],
      "memory_access_policy": "engineering_owner_policy"
    },
    {
      "agent_id": "content_leader",
      "department_id": "content",
      "role": "Department Owner",
      "model": "default-reasoning-model",
      "metadata": {
        "name": "Content Leader",
        "description": "Reads the shared discussion blackboard, proposes launch messaging, and writes audience-facing deliverables back into the discussion.",
        "profile": "writing",
        "tool_policy": "planning_only",
        "allowed_commands": ["CHECK_IN", "NEW_TICKET"],
        "required_commands": ["CHECK_IN"]
      },
      "description": "Turns the discussion into a content ticket with narrative and launch asset requirements.",
      "responsibilities": ["message_strategy", "launch_narrative", "frame_content_ticket"],
      "input_contract": "discussion_blackboard",
      "output_contract": "content_ticket",
      "skills": ["content_strategy", "launch_copy"],
      "mcp_servers": [],
      "tools": [],
      "memory_access_policy": "content_owner_policy"
    }
  ],
  "discussion_policy": {
    "mode": "parallel_review",
    "max_rounds": 1,
    "conflict_resolution": "supervisor_decision",
    "required_outputs": ["strategy_ticket", "engineering_ticket", "content_ticket"]
  },
